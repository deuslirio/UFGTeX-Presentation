% \sectionslide[color]{Title}
% Registers a section and auto-generates a mainpoint transition frame.
% Color is optional — defaults to DarkGray.
% To opt-in, add \AtBeginSection to your preamble (see below).
% Compatible with \definecolor custom colors defined in the .tex file.
\newcommand{\currentsectioncolor}{DarkGray}
