}{%
	\end{tabular}%
	\end{adjustbox}%
}

% Stat display: large number + label, use inside a column
\newcommand{\stat}[2]{%
	\centering%
	{\usebeamercolor[fg]{normal text}\bfseries\fontsize{40}{44}\selectfont #1}\par\vspace{0.3em}%
	{\footnotesize #2\par}%
}

% Vertical separator between stat columns — place in a \column{0.03\textwidth}
\newcommand{\statsep}{%
	\centering\color{LightGray}\rule{1pt}{2cm}%
}

% Hexagonal profile photo with PrimaryColor border.
% Usage: \profilephoto[size]{figs/photo.png}{FL}  (FL = initials shown when file missing)
% If the file does not exist, renders a PrimaryColor hexagon with white initials.
\newcommand{\profilephoto}[3][3.5cm]{%
	\begin{tikzpicture}
		\IfFileExists{#2}{%
			\node[regular polygon, regular polygon sides=6,
				  draw=PrimaryColor, line width=4pt,
				  inner sep=0pt, minimum size=#1,
				  rotate=90,
				  path picture={
					  \node at (path picture bounding box.center){%
						  \includegraphics[height=#1]{#2}};
				  }] {};
		}{%
			\node[regular polygon, regular polygon sides=6,
				  draw=PrimaryColor, line width=4pt, fill=PrimaryColor,
				  inner sep=0pt, minimum size=#1, rotate=90] (hex) {};
			\node[white, font=\bfseries\Large] at (hex.center) {#3};
		}%
	\end{tikzpicture}%
}

% Quote block: thick left border, italic text, right-aligned attribution
\newcommand{\quoteblock}[2]{%
	\vspace{\fill}%
	\begin{adjustbox}{max width=0.98\textwidth,clip}%
	\begin{tabular}{!{\color{PrimaryColor}{\vrule width 6pt}}>{\columncolor[gray]{0.97}}m{\textwidth}}%
		{\large\itshape #1}\\[0.5em]%
		{\small\upshape\hfill --- #2}%
	\end{tabular}%
	\end{adjustbox}%
	\vspace{\fill}%
}

